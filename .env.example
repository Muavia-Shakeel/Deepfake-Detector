# ============================================================
# Hybrid Ensemble Deepfake Detector — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# ============================================================

# --- App ---
APP_ENV=development          # development | production
SECRET_KEY=change_me_to_a_random_256bit_string

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Upload Storage ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=100

# --- Device ---
DEVICE=cuda                  # cuda | cpu

# --- Optional: HuggingFace token (if downloading gated models) ---
HF_TOKEN=

# --- Optional: Weights & Biases (experiment tracking) ---
WANDB_API_KEY=
WANDB_PROJECT=fyp-deepfake
WANDB_ENTITY=
